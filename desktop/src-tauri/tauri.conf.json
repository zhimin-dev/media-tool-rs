{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "media-tool-rs",
  "version": "0.0.0",
  "identifier": "com.wj.mediatoolrs",
  "build": {
    "beforeDevCommand": "npm run dev:with-server:tauri",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "media-tool-rs",
        "width": 1200,
        "height": 800,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
